M73 P91 R0

; --- Lower nozzle close to bed ---
G1 Z1 F600           ; go to 1mm height
M73 P93 R0

; --- Push print off ---
G1 Y-110 F1500       ; push bed back (eject print)
M73 P95 R0


; reset position
G28 X Y                ; re-home XY

; --- LOOP BACK ---
M808
M73 P100 R0
